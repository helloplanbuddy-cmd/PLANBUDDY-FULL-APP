# ============================================================
# PlanBuddy — Environment Variables
# Copy this file to .env.local and fill in your values.
# Variables marked REQUIRED must be set; OPTIONAL have safe defaults.
# ============================================================

# ── AI ──────────────────────────────────────────────────────
# REQUIRED: Anthropic API key for Claude AI (trip planning + buddy chat)
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth & Security ──────────────────────────────────────────
# REQUIRED: Secret for signing JWT access tokens (≥32 chars, random)
JWT_SECRET=replace-with-at-least-32-random-characters-here

# REQUIRED: Secret for signing JWT refresh tokens (≥32 chars, different from above)
JWT_REFRESH_SECRET=another-32-character-random-secret-here

# ── Database ─────────────────────────────────────────────────
# REQUIRED: PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/planbuddy

# ── SMS / OTP ─────────────────────────────────────────────────
# REQUIRED: "twilio" for production, "mock" for local dev (logs OTP to console)
SMS_PROVIDER=mock

# Twilio credentials — only required when SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── Redis (Rate Limiting & Sessions) ─────────────────────────
# OPTIONAL: Upstash Redis REST URL. Falls back to in-memory (not recommended for production).
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ── Observability ─────────────────────────────────────────────
# OPTIONAL: Sentry DSN for error tracking
SENTRY_DSN=https://xxxx@oxxxxxx.ingest.sentry.io/xxxxxxx

# OPTIONAL: OpenTelemetry OTLP endpoint (e.g. Honeycomb, Grafana Cloud)
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io

# ── Frontend / Client-side ────────────────────────────────────
# OPTIONAL: PostHog analytics key (NEXT_PUBLIC_ prefix = exposed to browser)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxx

# REQUIRED in production: Full public URL of the app (used for OG tags, redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OPTIONAL: Base URL for backend API (leave empty = same origin / Next.js API routes)
NEXT_PUBLIC_API_BASE_URL=

# ── App Config ────────────────────────────────────────────────
# OPTIONAL: Comma-separated allowed CORS origins for /api/* routes
ALLOWED_ORIGINS=http://localhost:3000

# OPTIONAL: Set to "true" to disable all AI calls (returns stub responses — useful for testing)
DISABLE_AI=false

# OPTIONAL: Node environment (next.js sets this automatically)
NODE_ENV=development
