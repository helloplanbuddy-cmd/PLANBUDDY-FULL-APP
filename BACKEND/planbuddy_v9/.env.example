# PlanBuddy Backend — Environment Configuration (.env.example)
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# config/env.js validates these at startup and exits on missing required vars.
#
# IMPORTANT PRODUCTION NOTES:
#   1. Never commit .env to git — it contains secrets
#   2. Use a secrets manager (AWS Secrets Manager, HashiCorp Vault, etc.)
#   3. For development, create .env from this file
#   4. See .env.production and .env.staging for environment-specific templates

# ─── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ─── Database (REQUIRED) ──────────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/database
# For development: postgresql://postgres:password@localhost:5432/planbuddy
# For production: use managed service (AWS RDS, Azure Database, etc.)
DATABASE_URL=postgresql://postgres:Helloplanbuddy%40123@db.paxhzxkrqcymdqdavexp.supabase.co:5432/postgres

# Pool tuning (connections per instance in cluster mode)
# Safe formula: DB_POOL_MAX × PM2_INSTANCES ≤ PG_MAX_CONNECTIONS × 0.8
DB_POOL_MAX=35
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=30000
HTTP_REQUEST_TIMEOUT_MS=30000
HTTP_HEADERS_TIMEOUT_MS=61000
DB_MAX_CONNECTIONS=100

# ─── Redis (REQUIRED for queue workers) ────────────────────────────────────────
# For development: redis://127.0.0.1:6379
# For production: use managed service (AWS ElastiCache, Azure Cache, etc.)
UPSTASH_REDIS_REST_URL="https://alive-moccasin-151694.upstash.io"
UPSTASH_REDIS_REST_TOKEN="gQAAAAAAAlCOAAIgcDI5NTI4MGU4ZDIxMDA0MGExYjNhOGZiMjlkYzUwMjQxZA"

# Redis resilience tuning
REDIS_MAX_RECONNECT_ATTEMPTS=20
REDIS_CIRCUIT_COOLDOWN_MS=60000
REDIS_BASE_RETRY_MS=100
REDIS_MAX_RETRY_MS=30000
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_COMMAND_TIMEOUT_MS=3000
REDIS_KEEP_ALIVE_MS=30000
REDIS_JTI_CACHE_TTL=60
REDIS_USER_ACTIVE_TTL=60
REDIS_FAIL_CLOSED=true

# ─── JWT (REQUIRED) ───────────────────────────────────────────────────────────
# SECURITY: Generate random 64-char string for production
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_random_64_character_jwt_secret_in_production
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=30d
MAX_SESSION_LIMIT=5
MAX_SESSION_LIFETIME=30d

# ─── Razorpay (REQUIRED) ──────────────────────────────────────────────────────
# Dev: Razorpay TEST keys (rzp_test_*)
# Prod: Razorpay LIVE keys (rzp_live_*)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins
# Dev: http://localhost:3000,http://localhost:5173
# Prod: https://app.planbuddy.in,https://www.planbuddy.in
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Email (optional) ─────────────────────────────────────────────────────────
# Option 1: Resend
RESEND_API_KEY=

# Option 2: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
FROM_EMAIL=noreply@planbuddy.in
FROM_NAME=PlanBuddy
SUPPORT_EMAIL=support@planbuddy.in

# ─── Logging ──────────────────────────────────────────────────────────────────
# Log level: debug, info, warn, error, fatal
LOG_LEVEL=info
LOG_PRETTY=false

# ─── Alerts (optional) ────────────────────────────────────────────────────────
# Slack incoming webhook
SLACK_WEBHOOK_URL=
ALERT_EMAIL=
SERVICE_NAME=planbuddy-backend

# ─── Metrics ──────────────────────────────────────────────────────────────────
# IPs allowed to access /metrics endpoint
METRICS_ALLOWED_IPS=127.0.0.1,::1,::ffff:127.0.0.1

# ─── Security: Proxy Validation ────────────────────────────────────────────────
# CRITICAL: Set this to your load balancer's IP(s) to prevent X-Forwarded-For spoofing
# Format: comma-separated list of IPs or CIDR blocks
# Example: 10.0.0.100,10.0.0.101,10.0.0.0/24
# If empty, X-Forwarded-For headers will be stripped (fail-safe, but rate limiting won't work)
# IMPORTANT: Firewall rules must also prevent direct connections to app port
KNOWN_PROXY_IPS=

# ─── Idempotency ──────────────────────────────────────────────────────────────
IDEMPOTENCY_TTL_HOURS=24

# ─── Workers ──────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=5
PM2_INSTANCES=2

# ─── App Version ───────────────────────────────────────────────────────────────
APP_VERSION=9.0.0
