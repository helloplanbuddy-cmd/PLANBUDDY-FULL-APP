# ──────────────────────────────────────────────────────────────────────
# PlanBuddy Backend — npm configuration
# P0-10 FIX: Supply-chain policy.
# ──────────────────────────────────────────────────────────────────────

# Fail CI on any dependency with a known security advisory at HIGH or above.
# This applies to `npm install` and `npm ci` invocations.
audit-level=high

# Save exact versions for production deps (no caret) in lockfile;
# the package.json keeps ^ for development readability.
save-exact=false

# Use the public npm registry by default. Override with --registry
# for private mirrors in CI (see .github/workflows/ci.yml).
registry=https://registry.npmjs.org/

# Stricter engine constraints — align with Dockerfile (node:20-alpine).
engine-strict=true

# Don't auto-create a package-lock when running `npm install` in production.
package-lock=true

# Disable funding messages and update-notifier for cleaner CI logs.
fund=false
update-notifier=false
