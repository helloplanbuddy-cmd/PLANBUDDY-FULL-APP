# PlanBuddy Backend — Environment Configuration (.env.example)
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# config/env.js validates these at startup and exits on missing required vars.

# ─── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ─── Database (REQUIRED) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:Helloplanbuddy%40123@db.paxhzxkrqcymdqdavexp.supabase.co:5432/postgres

# Pool tuning
DB_POOL_MAX=35
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=30000
DB_MAX_CONNECTIONS=100

# ─── Redis (REQUIRED for queue workers, OPTIONAL for cache) ───────────────────
UPSTASH_REDIS_REST_URL="https://alive-moccasin-151694.upstash.io"
UPSTASH_REDIS_REST_TOKEN="gQAAAAAAAlCOAAIgcDI5NTI4MGU4ZDIxMDA0MGExYjNhOGZiMjlkYzUwMjQxZA"

# Redis resilience tuning (Phase 1 Hardening)
# Max reconnect attempts before circuit breaker opens
REDIS_MAX_RECONNECT_ATTEMPTS=20
# Circuit breaker cooldown in ms after max retries exceeded
REDIS_CIRCUIT_COOLDOWN_MS=60000
# Base retry delay in ms
REDIS_BASE_RETRY_MS=100
# Max retry delay cap in ms
REDIS_MAX_RETRY_MS=30000
# Redis connect timeout in ms
REDIS_CONNECT_TIMEOUT_MS=5000
# Redis command timeout in ms
REDIS_COMMAND_TIMEOUT_MS=3000
# TCP keep-alive in ms
REDIS_KEEP_ALIVE_MS=30000

# Redis cache TTLs
REDIS_JTI_CACHE_TTL=60
REDIS_USER_ACTIVE_TTL=60

# ─── JWT (REQUIRED) ───────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_64_character_string_in_production
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=30d
MAX_SESSION_LIMIT=5
MAX_SESSION_LIFETIME=30d

# ─── Razorpay (REQUIRED) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Email (optional) ─────────────────────────────────────────────────────────
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
FROM_EMAIL=noreply@planbuddy.in
FROM_NAME=PlanBuddy
SUPPORT_EMAIL=support@planbuddy.in

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=false

# ─── Alerts (optional) ────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
ALERT_EMAIL=
SERVICE_NAME=planbuddy-backend

# ─── Metrics ──────────────────────────────────────────────────────────────────
METRICS_ALLOWED_IPS=127.0.0.1,::1,::ffff:127.0.0.1

# ─── Idempotency ──────────────────────────────────────────────────────────────
IDEMPOTENCY_TTL_HOURS=24

# ─── Workers ──────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=5
PM2_INSTANCES=2

# ─── Rate Limiting ────────────────────────────────────────────────────────────
REDIS_FAIL_CLOSED=true
